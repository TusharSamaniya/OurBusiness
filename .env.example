# Database
DATABASE_URL=postgresql://agency_user:agency_pass@localhost:5432/agency_db

# Security
SECRET_KEY=change-this-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
PROJECT_NAME=Agency Backend
ENVIRONMENT=development

# CORS - comma separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Email - sign up free at https://resend.com to get an API key.
# Without RESEND_API_KEY and EMAIL_TO set, leads still save fine - you
# just won't get an email notification (this is intentional, not a bug).
RESEND_API_KEY=
EMAIL_FROM=hello@yourdomain.com
EMAIL_TO=your-personal-inbox@example.com

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

ANTHROPIC_API_KEY=